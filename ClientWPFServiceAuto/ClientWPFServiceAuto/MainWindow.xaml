<Window x:Class="ClientWPFServiceAuto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Service Auto" Height="500" Width="900" Background="#F4F6F9" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PARTEA STÂNGĂ: Formularul complet -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="🚗 DATE MAȘINĂ" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>

            <TextBlock Text="ID Mașină (Gol pt. adăugare):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox x:Name="txtId" Height="28" Margin="0,0,0,10" Padding="4" FontSize="14" Background="#FFF9C4" IsReadOnly="True" ToolTip="Alege din tabel pentru a modifica/șterge"/>

            <TextBlock Text="Număr Înmatriculare:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox x:Name="txtNumar" Height="28" Margin="0,0,0,10" Padding="4" FontSize="14"/>

            <TextBlock Text="Marca Mașinii:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox x:Name="txtMarca" Height="28" Margin="0,0,0,10" Padding="4" FontSize="14"/>

            <TextBlock Text="Problema Reclamată:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox x:Name="txtProblema" Height="60" TextWrapping="Wrap" Margin="0,0,0,15" Padding="4" FontSize="14"/>

            <!-- Butoanele CRUD -->
            <Button Content="➕ Adaugă Mașină Nouă" Height="35" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnAdauga_Click" Margin="0,0,0,8" Cursor="Hand"/>
            <Button Content="✏️ Modifică Mașină" Height="35" Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnModifica_Click" Margin="0,0,0,8" Cursor="Hand"/>
            <Button Content="🗑️ Șterge Mașină" Height="35" Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnSterge_Click" Cursor="Hand"/>
        </StackPanel>

        <!-- PARTEA DREAPTĂ: Căutare și Tabel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Bara de Căutare -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Caută după Nr:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                <TextBox x:Name="txtCautare" Width="150" Height="30" Padding="4" FontSize="14" Margin="0,0,10,0"/>
                <Button Content="🔍 Caută" Width="90" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnCauta_Click" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="🔄 Toate" Width="90" Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnIncarca_Click" Cursor="Hand"/>
            </StackPanel>

            <!-- Tabelul (Observă adăugarea lui SelectionChanged la final) -->
            <!-- Tabelul (Acum cu stiluri inteligente) -->
            <DataGrid x:Name="gridMasini" Grid.Row="1" AutoGenerateColumns="False" 
                      HeadersVisibility="Column" FontSize="14" IsReadOnly="True" 
                      BorderBrush="#DDD" BorderThickness="1"
                      SelectionChanged="gridMasini_SelectionChanged">

                <!-- AICI ESTE MAGIA CULORILOR -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <!-- Culoarea standard pentru rândurile nerezolvate -->
                        <Setter Property="Background" Value="White" />

                        <Style.Triggers>
                            <!-- Declansator: Dacă Problema este exact "Rezolvat" -->
                            <DataTrigger Binding="{Binding Problema}" Value="Rezolvat">
                                <Setter Property="Background" Value="#C8E6C9" />
                                <!-- Un verde deschis plăcut -->
                                <Setter Property="Foreground" Value="#1B5E20" />
                                <!-- Scris verde închis -->
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <!-- Scris puțin mai gros -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- Coloanele tabelului -->
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="Nr. Înmatriculare" Binding="{Binding NumarInmatriculare}" Width="150"/>
                    <DataGridTextColumn Header="Marca" Binding="{Binding Marca}" Width="120"/>
                    <DataGridTextColumn Header="Problema" Binding="{Binding Problema}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>